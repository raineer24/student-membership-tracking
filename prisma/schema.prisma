// File: prisma/schema.prisma - COMPLETE SCHEMA WITH TRAINING SESSIONS
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// EXISTING MODELS (preserved exactly)
model User {
  id              Int               @id @default(autoincrement())
  name            String
  email           String            @unique
  password        String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  role            String            @default("student")
  studentId       Int?
  student         Student?
  
  // NEW: Training session relationship
  trainingSessions TrainingSession[]
  weekendEvents    WeekendEvent[]
}

model Student {
  id              Int               @id @default(autoincrement())
  name            String
  email           String            @unique
  phone           String?
  userId          Int               @unique
  
  // Enhanced fields with safe defaults
  monthlyRate     Float             @default(1400)
  isLegacyStudent Boolean           @default(false)
  
  // EXISTING relationships (preserved)
  memberships     Membership[]
  payments        Payment[]
  reminders       Reminder[]
  user            User              @relation(fields: [userId], references: [id])
  
  // NEW: Training session relationship for attendance tracking
  trainingSessions TrainingSession[]
  
  // Enhanced indexes for performance
  @@index([monthlyRate])
  @@index([isLegacyStudent])
  @@index([phone])
  @@index([email])
}

model Membership {
  id        Int             @id @default(autoincrement())
  startDate DateTime
  endDate   DateTime
  overdue   Boolean         @default(false)
  studentId Int
  isActive  Boolean         @default(true)
  type      MembershipType  @default(MONTHLY)
  student   Student         @relation(fields: [studentId], references: [id])
  
  @@index([studentId])
  @@index([endDate])
  @@index([overdue])
  @@index([isActive])
}

model Payment {
  id          Int             @id @default(autoincrement())
  amount      Float
  method      PaymentMethod   @default(CASH)
  description String?
  status      PaymentStatus   @default(COMPLETED)
  paidAt      DateTime        @default(now())
  studentId   Int
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  student     Student         @relation(fields: [studentId], references: [id])
  
  @@index([studentId])
  @@index([paidAt])
  @@index([status])
  @@index([amount])
  @@index([method])
}

model Reminder {
  id          Int      @id @default(autoincrement())
  studentId   Int
  method      String   @default("SMS")
  sentAt      DateTime @default(now())
  status      String   @default("SENT")
  message     String?
  phoneNumber String?
  cost        Float?
  response    String?
  retryCount  Int      @default(0)
  student     Student  @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([sentAt])
  @@index([status])
  @@index([phoneNumber])
  @@index([cost])
}

// EXISTING MODEL: WeekendEvent (preserved)
model WeekendEvent {
  id              Int       @id @default(autoincrement())
  eventType       EventType @default(GENERAL)
  title           String    @db.VarChar(100)
  message         String    @db.VarChar(300)
  startDate       DateTime
  endDate         DateTime?
  sendSMS         Boolean   @default(false)
  priority        Priority  @default(NORMAL)
  estimatedReach  Int       @default(0)
  estimatedCost   Decimal   @default(0.00) @db.Decimal(10, 2)
  
  creatorId       Int
  creator         User      @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([eventType])
  @@index([startDate])
  @@index([endDate])
  @@index([creatorId])
  @@index([priority])
  @@index([createdAt])
}

// NEW MODEL: TrainingSession - Core Feature for Attendance Tracking
model TrainingSession {
  id               Int                @id @default(autoincrement())
  
  // Student and session relationships
  studentId        Int
  student          Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  creatorId        Int
  creator          User               @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  
  // Session details aligned with martial arts program
  sessionType      SessionType        @default(WEEKEND)
  sessionDate      DateTime
  duration         Int                @default(90)        // Minutes (90-minute sessions)
  
  // Martial arts specific fields
  attendanceStatus AttendanceStatus   @default(PRESENT)
  skillsWorkedOn   String[]           @default([])        // Array of skills practiced
  notes            String?                                 // Instructor notes
  
  // Audit fields
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  
  // Performance indexes for 30-day queries
  @@index([studentId])
  @@index([sessionDate])
  @@index([sessionType])
  @@index([attendanceStatus])
  @@index([creatorId])
  @@index([studentId, sessionDate])      // Composite for student attendance queries
  @@index([sessionDate, sessionType])    // Composite for weekend/weekday analysis
}

// EXISTING ENUMS (preserved)
enum MembershipType {
  MONTHLY
  YEARLY
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  ONLINE
  CHECK
  OTHER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

// EXISTING ENUMS for Weekend Events
enum EventType {
  NO_CLASSES
  GENERAL
  BANNER
  SMS
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// NEW ENUMS for Training Sessions
enum SessionType {
  WEEKEND        // Primary schedule: Saturday-Sunday 10:00am-11:30am
  WEEKDAY        // Secondary schedule: Monday, Wednesday, Friday
  TRIAL          // Trial sessions for new students
  MAKEUP         // Makeup sessions for missed classes
}

enum AttendanceStatus {
  PRESENT        // Student attended and participated
  ABSENT         // Student did not attend
  LATE           // Student arrived late but participated
  LEFT_EARLY     // Student left before session ended
}