// File: prisma/schema.prisma
// SAFE: Added updatedAt with default value to preserve existing data

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int               @id @default(autoincrement())
  name             String?
  email            String            @unique
  password         String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  role             String            @default("student")
  studentId        Int?
  
  student          Student?
  trainingSessions TrainingSession[]
}

model Student {
  id               Int               @id @default(autoincrement())
  name             String
  email            String            @unique
  userId           Int               @unique
  phone            String?
  isLegacyStudent  Boolean           @default(false)
  monthlyRate      Float             @default(1400)
  age              Int?              
  parentName       String?             
  parentPhone      String?           
  program          String            @default("Kids")  
  
  user             User              @relation(fields: [userId], references: [id])
  memberships      Membership[]
  payments         Payment[]
  reminders        Reminder[]
  trainingSessions TrainingSession[]
}

// SAFE: Added fields with default values to avoid data loss
model Membership {
  id        Int             @id @default(autoincrement())
  startDate DateTime
  endDate   DateTime
  overdue   Boolean         @default(false)
  studentId Int
  isActive  Boolean         @default(true)
  type      MembershipType  @default(MONTHLY)
  createdAt DateTime        @default(now())        // SAFE: Has default
  updatedAt DateTime        @default(now()) @updatedAt  // SAFE: Default + auto-update
  
  student   Student         @relation(fields: [studentId], references: [id])
  
  @@index([studentId])
  @@index([endDate])
  @@index([createdAt])
}

model Payment {
  id          Int             @id @default(autoincrement())
  amount      Float
  method      PaymentMethod   @default(CASH)
  description String?
  status      PaymentStatus   @default(COMPLETED)
  paidAt      DateTime        @default(now())
  studentId   Int
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  
  student     Student         @relation(fields: [studentId], references: [id])
}

model Reminder {
  id          Int      @id @default(autoincrement())
  studentId   Int
  method      String   @default("SMS")
  sentAt      DateTime @default(now())
  status      String   @default("SENT")
  message     String?
  phoneNumber String?
  cost        Float?
  response    String?
  
  student     Student  @relation(fields: [studentId], references: [id])
}

// TrainingSession model
model TrainingSession {
  id               Int              @id @default(autoincrement())
  studentId        Int
  sessionType      SessionType      @default(WEEKEND)
  sessionDate      DateTime
  attendanceStatus AttendanceStatus @default(PRESENT)
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  createdBy        Int?
  
  student          Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  creator          User?            @relation(fields: [createdBy], references: [id])
  
  @@index([studentId])
  @@index([sessionDate])
  @@index([sessionType])
  @@index([attendanceStatus])
}

enum MembershipType {
  MONTHLY
  YEARLY
}

enum PaymentMethod {
  CASH
  GCASH
  BANK_TRANSFER
  CREDIT_CARD
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum AttendanceStatus {
  REGISTERED
  PRESENT
  ABSENT
  LATE
  LEFT_EARLY
}

enum SessionType {
  WEEKEND     // Primary weekend sessions
  WEEKDAY     // Monday, Wednesday, Friday sessions
  TRIAL       // Trial sessions for new students
  MAKEUP      // Makeup sessions for missed classes
}