// Line 31-55: ENHANCED Student model with grandfathered pricing fields
model Student {
  id            Int          @id @default(autoincrement())
  name          String
  email         String       @unique
  phone         String?                    // Required for SMS integration
  userId        Int          @unique
  
  // Line 38-43: NEW GRANDFATHERED PRICING FIELDS
  monthlyRate   Float        @default(1400)   // Individual monthly rate (₱1,000, ₱1,200, ₱1,400)
  isLegacyStudent Boolean    @default(false)  // Flag for grandfathered pricing
  
  // Line 45-50: Relationships
  memberships   Membership[]
  payments      Payment[]
  reminders     Reminder[]                 // SMS reminder relationship
  user          User         @relation(fields: [userId], references: [id])
  
  // Line 52-55: Enhanced indexes for efficient pricing and SMS queries
  @@index([monthlyRate])
  @@index([isLegacyStudent])
  @@index([phone])                         // For SMS functionality
  @@index([email])                         // For general lookups
}

// Line 56-70: Membership model - Tracks student membership periods and overdue status
model Membership {
  id        Int            @id @default(autoincrement())
  startDate DateTime
  endDate   DateTime
  overdue   Boolean        @default(false)  // Critical for SMS reminder logic
  studentId Int
  isActive  Boolean        @default(true)
  type      MembershipType @default(MONTHLY)
  student   Student        @relation(fields: [studentId], references: [id])
  
  // Line 66-70: Indexes for efficient membership queries
  @@index([studentId])
  @@index([endDate])
  @@index([overdue])
  @@index([isActive])
}

// Line 71-90: Payment model - Enhanced for grandfathered pricing tracking
model Payment {
  id          Int           @id @default(autoincrement())
  amount      Float                        // Amount paid (validated against student's individual rate)
  method      PaymentMethod @default(CASH)
  description String?                      // Enhanced to include pricing tier context
  status      PaymentStatus @default(COMPLETED)
  paidAt      DateTime      @default(now()) // Supports historical payment dates
  studentId   Int
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  student     Student       @relation(fields: [studentId], references: [id])
  
  // Line 83-90: Enhanced indexes for payment analytics and reporting
  @@index([studentId])
  @@index([paidAt])
  @@index([status])
  @@index([amount])
  @@index([method])
}

// Line 91-115: Reminder model - Complete SMS integration support
model Reminder {
  id          Int      @id @default(autoincrement())
  studentId   Int
  method      String   @default("SMS")           // SMS method for payment reminders
  sentAt      DateTime @default(now())           // Timestamp of SMS delivery
  status      String   @default("SENT")          // SENT, FAILED, PENDING
  message     String?                            // SMS content (optional storage)
  phoneNumber String?                            // Phone number used (for audit)
  cost        Float?                             // SMS cost tracking (₱0.35 per SMS)
  response    String?                            // Provider response (for debugging)
  retryCount  Int      @default(0)               // Failed delivery retry counter
  student     Student  @relation(fields: [studentId], references: [id])

  // Line 105-115: Comprehensive indexes for SMS analytics and rate limiting
  @@index([studentId])
  @@index([sentAt])
  @@index([status])
  @@index([phoneNumber])
  @@index([cost])
}

// Line 116-125: MembershipType enum - Membership duration options
enum MembershipType {
