// File: prisma/schema.prisma - Enhanced schema with training session tracking
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Lines 10-35: Enhanced User model (preserved exactly)
model User {
  id              Int             @id @default(autoincrement())
  name            String
  email           String          @unique
  password        String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  role            String          @default("student")
  studentId       Int?
  student         Student?
  
  // Weekend events relationship
  weekendEvents   WeekendEvent[]
}

// Lines 40-70: Enhanced Student model with training fields
model Student {
  id              Int             @id @default(autoincrement())
  name            String
  email           String          @unique
  phone           String?
  userId          Int             @unique
  
  // Enhanced fields with safe defaults
  monthlyRate     Float           @default(1400)
  isLegacyStudent Boolean         @default(false)
  
  // NEW: Training-related fields for enhanced tracking
  age             Int?
  parentName      String?
  parentPhone     String?
  program         String          @default("Kids")
  
  // EXISTING relationships (preserved)
  memberships     Membership[]
  payments        Payment[]
  reminders       Reminder[]
  user            User            @relation(fields: [userId], references: [id])
  
  // NEW: Training sessions relationship
  trainingSessions TrainingSession[]
  
  // Enhanced indexes for performance
  @@index([monthlyRate])
  @@index([isLegacyStudent])
  @@index([phone])
  @@index([email])
  @@index([program])
}

// Lines 75-100: Membership model (preserved exactly)
model Membership {
  id        Int             @id @default(autoincrement())
  startDate DateTime
  endDate   DateTime
  overdue   Boolean         @default(false)
  studentId Int
  isActive  Boolean         @default(true)
  type      MembershipType  @default(MONTHLY)
  student   Student         @relation(fields: [studentId], references: [id])
  
  @@index([studentId])
  @@index([endDate])
  @@index([overdue])
  @@index([isActive])
}

// Lines 105-130: Payment model (preserved exactly)
model Payment {
  id          Int             @id @default(autoincrement())
  amount      Float
  method      PaymentMethod   @default(CASH)
  description String?
  status      PaymentStatus   @default(COMPLETED)
  paidAt      DateTime        @default(now())
  studentId   Int
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  student     Student         @relation(fields: [studentId], references: [id])
  
  @@index([studentId])
  @@index([paidAt])
  @@index([status])
  @@index([amount])
  @@index([method])
}

// Lines 135-160: Reminder model (preserved exactly)
model Reminder {
  id          Int      @id @default(autoincrement())
  studentId   Int
  method      String   @default("SMS")
  sentAt      DateTime @default(now())
  status      String   @default("SENT")
  message     String?
  phoneNumber String?
  cost        Float?
  response    String?
  retryCount  Int      @default(0)
  student     Student  @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([sentAt])
  @@index([status])
  @@index([phoneNumber])
  @@index([cost])
}

// Lines 165-200: NEW TrainingSession model for 30+ day tracking
model TrainingSession {
  id              Int       @id @default(autoincrement())
  studentId       Int
  date            DateTime  @default(now()) @db.Date
  sessionType     String    @default("Weekend") // 'Weekend' or 'MWF-Weekday'
  dayOfWeek       String    // 'Saturday', 'Sunday', 'Monday', 'Wednesday', 'Friday'
  timeSlot        String    @default("10:00am-11:30am")
  duration        Int       @default(90) // 90 minutes weekend, 60 MWF
  attendance      String    @default("Present") // 'Present', 'Absent', 'Late'
  notes           String?   // Optional session notes
  createdAt       DateTime  @default(now())
  
  // Relationship to student
  student         Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  // Performance indexes for analytics queries
  @@index([studentId, date])
  @@index([sessionType, date])
  @@index([dayOfWeek])
  @@index([attendance])
  @@index([createdAt])
}

// Lines 205-235: WeekendEvent model (preserved exactly)
model WeekendEvent {
  id              Int       @id @default(autoincrement())
  eventType       EventType @default(GENERAL)
  title           String    @db.VarChar(100)
  message         String    @db.VarChar(300)
  startDate       DateTime
  endDate         DateTime?
  sendSMS         Boolean   @default(false)
  priority        Priority  @default(NORMAL)
  estimatedReach  Int       @default(0)
  estimatedCost   Decimal   @default(0.00) @db.Decimal(10, 2)
  
  creatorId       Int
  creator         User      @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([eventType])
  @@index([startDate])
  @@index([endDate])
  @@index([creatorId])
  @@index([priority])
  @@index([createdAt])
}

// Lines 240-260: EXISTING ENUMS (preserved exactly)
enum MembershipType {
  MONTHLY
  YEARLY
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  ONLINE
  CHECK
  OTHER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

// Lines 265-280: Weekend Events enums (preserved exactly)
enum EventType {
  NO_CLASSES
  GENERAL
  BANNER
  SMS
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}