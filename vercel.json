{
  "version": 2,
  "builds": [
    {
      "src": "pages/api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/auth/login",
      "dest": "/api/auth/login.js"
    },
    {
      "src": "/api/auth/register",
      "dest": "/api/auth/register.js"
    },
    {
      "src": "/api/students",
      "dest": "/api/students/index.js"
    },
    {
      "src": "/api/students/:id",
      "dest": "/api/students/[id].js"
    },
    {
      "src": "/api/memberships/me",
      "dest": "/api/memberships.js"
    },
    {
      "src": "/api/memberships/overdue",
      "dest": "/api/memberships.js"
    },
    {
      "src": "/api/memberships/create",
      "dest": "/api/memberships.js"
    },
    {
      "src": "/api/memberships(.*)",
      "dest": "/api/memberships.js"
    },
    {
      "src": "/api/payments/me",
      "dest": "/api/payments.js"
    },
    {
      "src": "/api/payments/:id",
      "dest": "/api/payments.js"
    },
    {
      "src": "/api/payments(.*)",
      "dest": "/api/payments.js"
    },
    {
      "src": "/api/dashboard",
      "dest": "/api/dashboard/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/"
    }
]
}