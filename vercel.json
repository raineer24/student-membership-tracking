{
  "version": 2,
  "builds": [
    {
      "src": "pages/api/auth.js",
      "use": "@vercel/node"
    },
    {
      "src": "pages/api/api.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/auth/login",
      "dest": "/api/auth.js"
    },
    {
      "src": "/api/auth/register",
      "dest": "/api/auth.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/api.js"
    }
  ]
}