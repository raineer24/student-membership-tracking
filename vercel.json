{
  "version": 2,
  "name": "student-membership-tracking",
  "builds": [
    {
      "src": "pages/api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/auth/(.*)",
      "dest": "/api/auth/:path*"
    },
    {
      "src": "/api/students/(.*)",
      "dest": "/api/students/:path*"
    },
     {
      "src": "/api/memberships/me",
      "dest": "/api/memberships.js"
    },
    {
      "src": "/api/memberships/overdue",
      "dest": "/api/memberships.js"
    },
        {
      "src": "/api/memberships/create",
      "dest": "/api/memberships.js"
    },
    {
      "src": "/api/memberships(.*)",
      "dest": "/api/memberships.js"
    },
    {
      "src": "/api/payments/me",
      "dest": "/api/payments.js"
    },
    {
      "src": "/api/payments(.*)",
      "dest": "/api/payments.js"
    },
    {
      "src": "/api/dashboard(.*)",
      "dest": "/api/dashboard/:path*"
    },
    {
      "src": "/(.*)",
      "dest": "/"
    }
  ]
}