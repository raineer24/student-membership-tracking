{
"version": 2,
"name": "student-membership-tracking",
"builds": [
{
"src": "api/**/.js",
"use": "@vercel/node"
}
],
"routes": [
{
"src": "/api/auth/(.)",
"dest": "/api/auth/$1"
},
{
"src": "/api/students/(.)",
"dest": "/api/students/$1"
},
{
"src": "/api/(.)",
"dest": "/api/$1"
},
{
"src": "/(.*)",
"dest": "/api/index.js"
}
]
}